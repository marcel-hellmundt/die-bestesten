# Options +FollowSymLinks
RewriteEngine On

RewriteCond %{SCRIPT_FILENAME} !-d
RewriteCond %{SCRIPT_FILENAME} !-f

RewriteRule ^.*$ ./index.html

<IfModule mod_headers.c>
  # index.html referenziert gehashte Bundle-Dateien -> darf nie stale gecacht werden,
  # sonst laedt ein Geraet nach einem Deploy Chunks, die auf dem Server geloescht wurden
  # (mirror --delete) und bekommt statt JS das SPA-Fallback-HTML zurueck.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
